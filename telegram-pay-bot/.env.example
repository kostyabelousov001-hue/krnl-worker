# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# TON Wallet Address where users will send payments
# Make sure this is a v4R2 or similar wallet address that you control
TON_WALLET_ADDRESS=your_ton_wallet_address_here

# Toncenter API Key (Get a free one from @tonapibot on Telegram)
# Optional but highly recommended to avoid rate limits
TONCENTER_API_KEY=your_toncenter_api_key_here

# Price of premium access in TON
PREMIUM_PRICE_TON=0.5
